{
  "name": "recepten-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "tsx ../tests/extractor.test.mjs && tsx ../tests/parseTimeFromStep.test.mjs",
    "build:android:preview": "eas build --platform android --profile preview",
    "build:android:prod": "eas build --platform android --profile production",
    "build:ios:preview": "eas build --platform ios --profile preview",
    "build:ios:prod": "eas build --platform ios --profile production",
    "build:all": "eas build --platform all --profile production",
    "submit:android": "eas submit --platform android --profile production",
    "submit:ios": "eas submit --platform ios --profile production"
  },
  "dependencies": {
    "@expo-google-fonts/fraunces": "^0.3.0",
    "@expo-google-fonts/inter": "^0.3.0",
    "@expo-google-fonts/jetbrains-mono": "^0.3.0",
    "@expo/vector-icons": "^15.0.3",
    "@types/react": "18.2.0",
    "expo": "~54.0.0",
    "expo-file-system": "~19.0.22",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-keep-awake": "~15.0.8",
    "expo-router": "~6.0.23",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "immer": "^10.1.1",
    "react": "18.3.1",
    "react-native": "0.79.2",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "use-sync-external-store": "^1.2.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react-native": "^4.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
}
