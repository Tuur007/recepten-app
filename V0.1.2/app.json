{
  "expo": {
    "name": "Recepten",
    "slug": "recepten-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "recepten",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tuur007.recepten"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#16a34a"
      },
      "package": "com.tuur007.recepten"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-file-system"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
