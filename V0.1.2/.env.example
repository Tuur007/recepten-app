# Supabase — cloud-sync, auth en family flows.
# Beide variabelen zijn nodig om de Supabase-client aan te maken; ontbreekt
# één van beide, dan blijft `supabase` `null` en draait de app puur lokaal
# (recepten, weekplanner, grocery — alles in SQLite).
#
# 1. Maak een kopie van dit bestand: `cp .env.example .env`
# 2. Vul de waarden in vanuit het Supabase dashboard → Project Settings → API
# 3. Herstart `expo start` (env vars worden enkel bij start ingelezen)
#
# Voor EAS builds: zet deze variabelen op de EAS server via
#   `eas env:create --scope project --name EXPO_PUBLIC_SUPABASE_URL --value ...`
# of via het EAS dashboard. NIET committen.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Sentry — crash reporting.
# De runtime-DSN heeft de EXPO_PUBLIC_ prefix nodig zodat Expo hem in de
# client-bundle zet (een Sentry-DSN is niet geheim). Leeg laten = Sentry uit
# (no-op, handig in dev).
EXPO_PUBLIC_SENTRY_DSN=
# Enkel build-time: de Sentry config-plugin / CLI uploadt hiermee sourcemaps
# tijdens EAS builds. Zet als EAS project-env. NIET committen.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
